generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mongodb"
}

model User {
    id        String  @id @default(auto()) @map("_id") @db.ObjectId
    clerkId   String  @unique
    email     String  @unique
    firstName String?
    lastName  String?
    imageUrl  String?

    // Subscription / Usage fields
    plan    Plan @default(FREE)
    credits Int  @default(5)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    resumes Resume[]
}

type Resume {
    id        String
    title     String
    content   String // Simplified for now, store as string or JSON string
    targetJob String?
    latex     String?
    createdAt DateTime @default(now())
    updatedAt DateTime @default(now())
}

enum Plan {
    FREE
    PRO
    SCALE
}
